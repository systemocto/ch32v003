void IRIG_Init(void) {
    // Configureer ook PD5 als Output Push-Pull voor IRIG-B
    IRIG_GPIO_PORT->CFGLR &= ~(0xF << (IRIG_PIN * 4)); 
    IRIG_GPIO_PORT->CFGLR |= (0x3 << (IRIG_PIN * 4));  
}

void IRIG_BouwFrame1(uint8_t u, uint8_t m, uint8_t s) {
    // 1. Wis de bitstream (alles op '0')
    for(uint8_t i = 0; i < 100; i++) irig_bits[i] = 0;

    // 2. Plaats de verplichte Position Identifiers (8ms pulsen) volgens de IRIG-B standaard
    irig_bits[0]  = 2; // P0 (Start van frame)
    irig_bits[9]  = 2; // P1
    irig_bits[19] = 2; // P2
    irig_bits[29] = 2; // P3
    irig_bits[39] = 2; // P4
    irig_bits[49] = 2; // P5
    irig_bits[59] = 2; // P6
    irig_bits[69] = 2; // P7
    irig_bits[79] = 2; // P8
    irig_bits[89] = 2; // P9
    irig_bits[99] = 2; // P5 (Laatste bit voor de omslag)

    // 3. Codeer Seconden (Bits 1-4 eenheden, Bits 6-8 tientallen)
    uint8_t s_een = s % 10; uint8_t s_tien = s / 10;
    if(s_een & 0x01) irig_bits[1] = 1; if(s_een & 0x02) irig_bits[2] = 1;
    if(s_een & 0x04) irig_bits[3] = 1; if(s_een & 0x08) irig_bits[4] = 1;
    if(s_tien & 0x01) irig_bits[5] = 1; if(s_tien & 0x02) irig_bits[6] = 1;
    if(s_tien & 0x04) irig_bits[7] = 1;

    // 4. Codeer Minuten (Bits 10-13 eenheden, Bits 15-17 tientallen)
    uint8_t m_een = m % 10; uint8_t m_tien = m / 10;
    if(m_een & 0x01) irig_bits[10] = 1; if(m_een & 0x02) irig_bits[11] = 1;
    if(m_een & 0x04) irig_bits[12] = 1; if(m_een & 0x08) irig_bits[13] = 1;
    if(m_tien & 0x01) irig_bits[15] = 1; if(m_tien & 0x02) irig_bits[16] = 1;
    if(m_tien & 0x04) irig_bits[17] = 1;

    // 5. Codeer Uren (Bits 20-23 eenheden, Bits 25-26 tientallen)
    uint8_t u_een = u % 10; uint8_t u_tien = u / 10;
    if(u_een & 0x01) irig_bits[20] = 1; if(u_een & 0x02) irig_bits[21] = 1;
    if(u_een & 0x04) irig_bits[22] = 1; if(u_een & 0x08) irig_bits[23] = 1;
    if(u_tien & 0x01) irig_bits[25] = 1; if(u_tien & 0x02) irig_bits[26] = 1;
}
void IRIG_BouwFrame(uint8_t u, uint8_t m, uint8_t s) {
    // Wis de bitstream (alles op '0')
    for(uint8_t i = 0; i < 100; i++) irig_bits[i] = 0;

    // Plaats de verplichte Position Identifiers (8ms pulsen)
    irig_bits[0]  = 2; // P0 (Start van frame)
    irig_bits[9]  = 2; // P1
    irig_bits[19] = 2; // P2
    irig_bits[29] = 2; // P3
    irig_bits[39] = 2; // P4
    irig_bits[49] = 2; // P5
    irig_bits[59] = 2; // P6
    irig_bits[69] = 2; // P7
    irig_bits[79] = 2; // P8
    irig_bits[89] = 2; // P9
    irig_bits[99] = 2; // P5 (Laatste bit voor de omslag)

    // Codeer Seconden (Bits 1-4 eenheden, Bits 6-8 tientallen)
    uint8_t s_een = s % 10; uint8_t s_tien = s / 10;
    if(s_een & 0x01) irig_bits[1] = 1; if(s_een & 0x02) irig_bits[2] = 1;
    if(s_een & 0x04) irig_bits[3] = 1; if(s_een & 0x08) irig_bits[4] = 1;
    if(s_tien & 0x01) irig_bits[5] = 1; if(s_tien & 0x02) irig_bits[6] = 1;
    if(s_tien & 0x04) irig_bits[7] = 1;

    // Codeer Minuten (Bits 10-13 eenheden, Bits 15-17 tientallen)
    uint8_t m_een = m % 10; uint8_t m_tien = m / 10;
    if(m_een & 0x01) irig_bits[10] = 1; if(m_een & 0x02) irig_bits[11] = 1;
    if(m_een & 0x04) irig_bits[12] = 1; if(m_een & 0x08) irig_bits[13] = 1;
    if(m_tien & 0x01) irig_bits[15] = 1; if(m_tien & 0x02) irig_bits[16] = 1;
    if(m_tien & 0x04) irig_bits[17] = 1;

    // Codeer Uren (Bits 20-23 eenheden, Bits 25-26 tientallen)
    uint8_t u_een = u % 10; uint8_t u_tien = u / 10;
    if(u_een & 0x01) irig_bits[20] = 1; if(u_een & 0x02) irig_bits[21] = 1;
    if(u_een & 0x04) irig_bits[22] = 1; if(u_een & 0x08) irig_bits[23] = 1;
    if(u_tien & 0x01) irig_bits[25] = 1; if(u_tien & 0x02) irig_bits[26] = 1;

    // --- MS OFFSET SYNC LOGICA ---
    // Haal de milliseconde offset op uit EEPROM register 0x07 (-127..+127 ms)
    //int32_t irig_ms_offset = (int32_t)((int8_t)i2c_eeprom[0x07]);

    // Converteer ms naar timer ticks (1 ms = 4 ticks van 250us)
    int32_t tick_offset = irig_ms_offset * 4; 

    // Bereken de nieuwe startpositie binnen de 4000 ticks van de seconde.
    // We trekken de tick_offset af om de puls te vervroegen bij een positieve offset.
    int32_t target_ticks = 0 - tick_offset;

    // Zorg dat het getal altijd binnen het bereik van 0 tot 3999 ticks valt (rollover)
    while (target_ticks < 0)      target_ticks += 4000;
    while (target_ticks >= 4000) target_ticks -= 4000;

    // Dwing de IRIG engine direct naar deze verschoven bit- en tick-positie
    __disable_irq();
    irig_bit_index = target_ticks / 40;   // Bepaal welke van de 100 bits nu actief moet zijn
    irig_tick_counter = target_ticks % 40;// Bepaal de sub-tick (0..39) binnen die bit
    __enable_irq();
}

