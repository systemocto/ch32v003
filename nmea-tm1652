/*
 * Initialiseer Timer 2 om interrupts te genereren op de LTC belfrequentie (4000 Hz)
 * Dit is nodig om de helft van een '1'-bit te kunnen timen (250 microseconden).
 */
void LTC_Timer_Init1(void) {
    // Schakel klok voor TIM2 in
    RCC->APB1PCENR |= RCC_APB1Periph_TIM2;
    
    // Configureer LTC GPIO Pin als Output Push-Pull
    LTC_GPIO_PORT->CFGLR &= ~(0xF << (LTC_PIN * 4));
    LTC_GPIO_PORT->CFGLR |= (0x3 << (LTC_PIN * 4)); 

    // TIM2 instellen voor 4000 Hz interrupt (250 us interval bij 24 MHz)
    TIM2->PSC = 24 - 1;                // Prescaler: Klok naar 1 MHz
    TIM2->ATRLR = 250 - 1;             // Auto-reload: 250 Ticks = 250 us
    TIM2->INTFR = 0;                   // Wis vlaggen
//    TIM2->DMAINTENR |= TIM_IT_Update;  // Update interrupt aanzetten
    TIM2->DMAINTENR |= TIM_UIE;

    NVIC_EnableIRQ(TIM2_IRQn);
    TIM2->CTLR1 |= TIM_CEN;        // Start Timer 2
}

void LTC_Timer_Init(void) {
    TIM_TimeBaseInitTypeDef TIM_TimeBaseStructure = {0};

    // 1. Klok inschakelen voor TIM2
    RCC_APB1PeriphClockCmd(RCC_APB1Periph_TIM2, ENABLE);
    
    // 2. Configureer LTC GPIO Pin als Output Push-Pull (PD3)
    GPIO_InitTypeDef GPIO_InitStructure = {0};
    RCC_APB2PeriphClockCmd(RCC_APB2Periph_GPIOD, ENABLE);
    GPIO_InitStructure.GPIO_Pin = GPIO_Pin_3;
    GPIO_InitStructure.GPIO_Mode = GPIO_Mode_Out_PP;
    GPIO_InitStructure.GPIO_Speed = GPIO_Speed_50MHz;
    GPIO_Init(LTC_GPIO_PORT, &GPIO_InitStructure);

    // 3. TIM2 instellen voor 4000 Hz interrupt (250 us bij 24 MHz)
    TIM_TimeBaseStructure.TIM_Period = 250 - 1;
    //TIM_TimeBaseStructure.TIM_Prescaler = 24 - 1;
//    TIM_TimeBaseStructure.TIM_Prescaler = 48 - 1;   // 48 MHz / 48 = 1 MHz (1 tick = 1 us)
    TIM_TimeBaseStructure.TIM_Prescaler = (EEN_SECONDE_CYCLI / 1000000) - 1;


    TIM_TimeBaseStructure.TIM_ClockDivision = TIM_CKD_DIV1;
    TIM_TimeBaseStructure.TIM_CounterMode = TIM_CounterMode_Up;
    TIM_TimeBaseInit(TIM2, &TIM_TimeBaseStructure);

    // 4. Wis vlaggen, zet de interrupt aan en start de timer
    TIM_ClearFlag(TIM2, TIM_FLAG_Update);
    TIM_ITConfig(TIM2, TIM_IT_Update, ENABLE);
    
    NVIC_EnableIRQ(TIM2_IRQn);
    TIM_Cmd(TIM2, ENABLE); // Dit vervangt de TIM_CR1_CEN regel volledig!
}

void LTC_BouwFrame1(uint8_t u, uint8_t m, uint8_t s, uint8_t f) {
    uint8_t tmp[10] = {0};

    // --- SPLIT TIJD & DATUM IN BCD NIBBLES ---
    uint8_t f_een = f % 10;  uint8_t f_tien = f / 10;
    uint8_t s_een = s % 10;  uint8_t s_tien = s / 10;
    uint8_t m_een = m % 10;  uint8_t m_tien = m / 10;
    uint8_t u_een = u % 10;  uint8_t u_tien = u / 10;

    // Haal de globale datumvariabelen op uit je ch32v003 code
    uint8_t d_een = interne_dag % 10;   uint8_t d_tien = interne_dag / 10;
    uint8_t ma_een = interne_maand % 10; uint8_t ma_tien = interne_maand / 10;
    uint8_t j_een = interne_jaar % 10;  uint8_t j_tien = interne_jaar / 10;

    // --- SMPTE / EBU 80-BITS INTERLEAVED BIT MAPPING ---
    
    // Byte 0: Bits 0-3 (Frame eenheden) + Bits 4-7 (User Bits 1: Dag eenheden)
    tmp[0] = (f_een & 0x0F) | ((d_een & 0x0F) << 4);

    // Byte 1: Bits 8-11 (Frame tientallen) + Bits 12-15 (User Bits 2: Dag tientallen)
    tmp[1] = (f_tien & 0x03) | ((d_tien & 0x0F) << 4); 
    // Bit 10 & 11 zijn eventueel Dropframe/Colorframe flags, hier op 0 gehouden

    // Byte 2: Bits 16-19 (Seconde eenheden) + Bits 20-23 (User Bits 3: Maand eenheden)
    tmp[2] = (s_een & 0x0F) | ((ma_een & 0x0F) << 4);

    // Byte 3: Bits 24-27 (Seconde tientallen) + Bits 28-31 (User Bits 4: Maand tientallen)
    tmp[3] = (s_tien & 0x07) | ((ma_tien & 0x0F) << 4);

    // Byte 4: Bits 32-35 (Minuut eenheden) + Bits 36-39 (User Bits 5: Jaar eenheden)
    tmp[4] = (m_een & 0x0F) | ((j_een & 0x0F) << 4);

    // Byte 5: Bits 40-43 (Minuut tientallen) + Bits 44-47 (User Bits 6: Jaar tientallen)
    tmp[5] = (m_tien & 0x07) | ((j_tien & 0x0F) << 4);

    // Byte 6: Bits 48-51 (Uur eenheden) + Bits 52-55 (User Bits 7: Vrij / Clock ID)
    // We kunnen hier de dynamisch uitgelezen dipsw (0-15) inladen als identificatie!
    tmp[6] = (u_een & 0x0F) | ((dipsw & 0x0F) << 4);

    // Byte 7: Bits 56-59 (Uur tientallen) + Bits 60-63 (User Bits 8: Status / Vrij)
    // Bit 58 is gereserveerd, Bit 59 is de Biphase Mark polarity correction bit
    tmp[7] = (u_tien & 0x03) | (0x00 << 4); 

    // Byte 8 & 9: Het dwingende lineaire Synchronisatiewoord (0xBFFC)
    // Uitgeschreven in bits van links naar rechts: 00111111 11111101
    tmp[8] = 0xFC; // Bits 64-71
    tmp[9] = 0xBF; // Bits 72-79

    // --- ATOMIC TRANSFERS NAAR HARDWARE BUFFER ---
    // We zetten interrupts heel kort uit om te voorkomen dat TIM2 halverwege 
    // een bit-transmissie een half geüpdatete frame-array uitleest.
    __disable_irq();
    for(uint8_t i = 0; i < 10; i++) {
        ltc_frame_buffer[i] = tmp[i];
    }
    __enable_irq();
}

void LTC_BouwFrame(uint8_t u, uint8_t m, uint8_t s, uint8_t f) {
    uint8_t tmp[10] = {0};
    
    // 1. Haal de offset op uit EEPROM register 0x06 en behandel direct als signed 8-bit integer (-127..+127)
//    int8_t offset = (int8_t)i2c_eeprom[0x06];
//    ltc_fr_offset = (int8_t)i2c_eeprom[0x06];


    // Stel hier je frame-rate in (bijv. 25 voor EBU, 30 voor SMPTE)
    const uint8_t FPS = 25; 

    // 2. Converteer de huidige invoertijd volledig naar frames (totaal aantal frames in de dag)
    int32_t totaal_frames = ((int32_t)u * 3600 + (int32_t)m * 60 + (int32_t)s) * FPS + f;

    // Pas de offset direct toe
    totaal_frames += ltc_fr_offset;

    // 3. Handhaaf rollover over de grens van een volledige dag (24 uur)
    int32_t frames_per_dag = 24L * 3600L * FPS;
    
    if (totaal_frames < 0) {
        totaal_frames += frames_per_dag;
    } else if (totaal_frames >= frames_per_dag) {
        totaal_frames -= frames_per_dag;
    }

    // 4. Herbereken de gecorrigeerde u, m, s, f parameters uit de frames
    f = totaal_frames % FPS;
    totaal_frames /= FPS;
    s = totaal_frames % 60;
    totaal_frames /= 60;
    m = totaal_frames % 60;
    u = totaal_frames / 60;

    // --- VANAF HIER IS JOUW BESTAANDE SPLIT & MAPPING LOGICA ACTIEF ---
    uint8_t f_een = f % 10;  uint8_t f_tien = f / 10;
    uint8_t s_een = s % 10;  uint8_t s_tien = s / 10;
    uint8_t m_een = m % 10;  uint8_t m_tien = m / 10;
    uint8_t u_een = u % 10;  uint8_t u_tien = u / 10;

    uint8_t d_een = interne_dag % 10;   uint8_t d_tien = interne_dag / 10;
    uint8_t ma_een = interne_maand % 10; uint8_t ma_tien = interne_maand / 10;
    uint8_t j_een = interne_jaar % 10;  uint8_t j_tien = interne_jaar / 10;

    // SMPTE / EBU 80-BITS INTERLEAVED BIT MAPPING
    tmp[0] = (f_een & 0x0F) | ((d_een & 0x0F) << 4);
    tmp[1] = (f_tien & 0x03) | ((d_tien & 0x0F) << 4); 
    tmp[2] = (s_een & 0x0F) | ((ma_een & 0x0F) << 4);
    tmp[3] = (s_tien & 0x07) | ((ma_tien & 0x0F) << 4);
    tmp[4] = (m_een & 0x0F) | ((j_een & 0x0F) << 4);
    tmp[5] = (m_tien & 0x07) | ((j_tien & 0x0F) << 4);
    tmp[6] = (u_een & 0x0F) | ((dipsw & 0x0F) << 4);
    tmp[7] = (u_tien & 0x03) | (0x00 << 4); 

    tmp[8] = 0xFC; 
    tmp[9] = 0xBF; 

    // ATOMIC TRANSFERS NAAR HARDWARE BUFFER
    __disable_irq();
    for(uint8_t i = 0; i < 10; i++) {
        ltc_frame_buffer[i] = tmp[i];
    }
    __enable_irq();
}


/*
 * Timer 2 Hardware Interrupt - Genereert het LTC signaal op de GPIO-pin
 */
void TIM2_IRQHandler(void) __attribute__((interrupt("WCH-Interrupt-fast")));
void TIM2_IRQHandler(void) {
    TIM2->INTFR = (uint16_t)~TIM_UIF; 

    // 2. Bepaal de huidige bit-index (0 t/m 79) en de sub-stap (0 of 1)
    uint8_t bit_index = ltc_stap_teller >> 1; // ltc_stap_teller / 2
    uint8_t sub_stap  = ltc_stap_teller & 0x01; // ltc_stap_teller % 2

    uint8_t byte_pos = bit_index >> 3;  // bit_index / 8
    uint8_t bit_pos  = bit_index & 0x07; // bit_index % 8

    // 3. Haal de bitwaarde op
    uint8_t actieve_bit = (ltc_frame_buffer[byte_pos] >> bit_pos) & 0x01;

    // 4. BPM Modulatie Beslissing Matrix
    uint8_t moet_toggeleren = 0;

    if (sub_stap == 0) {
        // De start van ELKE bitperiode moet ALTIJD toggeleren
        moet_toggeleren = 1;
    } else {
        // Halverwege de bitperiode: toggle ALLEEN als de bit een '1' is
        if (actieve_bit == 1) {
            moet_toggeleren = 1;
        }
    }

    // 5. Voer de toggle fysiek uit op de GPIO-poort
    if (moet_toggeleren) {
        ltc_output_state ^= 1;
        if (ltc_output_state) {
            LTC_GPIO_PORT->BSHR = (1 << LTC_PIN);
        } else {
            LTC_GPIO_PORT->BSHR = (1 << (LTC_PIN + 16));
        }
    }

    // 6. Schuif de teller op naar de volgende stap
    ltc_stap_teller++;
    if (ltc_stap_teller >= 160) {
        ltc_stap_teller = 0; // Frame compleet, begin opnieuw bij bit 0

        interne_frames++;

        if (interne_frames >= 25) {
            interne_frames = 0;
            interne_seconden++;
            if (interne_seconden >= 60) {
                interne_seconden = 0;
                interne_minuten++;
                if (interne_minuten >= 60) {
                    interne_minuten = 0;
                    interne_uren++;
                    if (interne_uren >= 24) {
                        interne_uren = 0;
                    }
                }
            }
#ifdef IRIGOUT
            IRIG_BouwFrame(interne_uren, interne_minuten, interne_seconden);
            irig_bit_index = 0; // Synchroniseer de IRIG bit-as strak met de LTC-as
            irig_tick_counter = 0;
#endif

        }
        
        LTC_BouwFrame(interne_uren, interne_minuten, interne_seconden, interne_frames);

    }


#ifdef IRIGOUT
    // ========================================================================
    // IRIG-B GENERATOR ENGINE (Elke interrupt = 250 us)
    // ========================================================================
    uint8_t huidige_irig_type = irig_bits[irig_bit_index];
    uint8_t irig_hoog_grens = 8; // Standaard Bit '0': 2 ms hoog = 8 ticks * 250us

    if (huidige_irig_type == 1) {
        irig_hoog_grens = 20;    // Bit '1': 5 ms hoog = 20 ticks
    } else if (huidige_irig_type == 2) {
        irig_hoog_grens = 32;    // Sync Marker (P): 8 ms hoog = 32 ticks
    }

    // PWM Schakelmomenten uitvoeren op IRIG_PIN
    if (irig_tick_counter < irig_hoog_grens) {
        IRIG_GPIO_PORT->BSHR = (1 << IRIG_PIN);        // Pin HOOG
    } else {
        IRIG_GPIO_PORT->BSHR = (1 << (IRIG_PIN + 16)); // Pin LAAG
    }

    irig_tick_counter++;
    if (irig_tick_counter >= 40) { // 40 ticks * 250us = 10 ms voorbij. Volgende bit!
        irig_tick_counter = 0;
        irig_bit_index++;
        if (irig_bit_index >= 100) {
            irig_bit_index = 0; // 100 bits = 1 seconde voorbij
        }
    }
    // ========================================================================
#endif
}

void TIM2_IRQHandler1(void) {
    if (TIM2->INTFR & TIM_UIF) {
        TIM2->INTFR = ~TIM_UIF; // Wis interrupt vlag

        if (ltc_sub_bit == 0) {
            // Haal de huidige bit op uit de frame buffer
            uint8_t byte_pos = ltc_bit_index / 8;
            uint8_t bit_pos = ltc_bit_index % 8;
            ltc_huidige_bit = (ltc_frame_buffer[byte_pos] >> bit_pos) & 0x01;

            // Elke bit start ALTIJD met een flankwisseling (BPM specificatie)
            ltc_output_state ^= 1;
            if (ltc_output_state) {
                LTC_GPIO_PORT->BSHR = (1 << LTC_PIN);
            } else {
                LTC_GPIO_PORT->BSHR = (1 << (LTC_PIN + 16));
            }

            if (ltc_huidige_bit == 1) {
                ltc_sub_bit = 1; // Bit is '1', we moeten halverwege nog een keer flippen
            } else {
                // Bit is '0', klaar met deze bit
                ltc_bit_index++;
            }
        } else {
            // Halverwege de '1' bit: wissel de flank nog een keer
            ltc_output_state ^= 1;
            if (ltc_output_state) {
                LTC_GPIO_PORT->BSHR = (1 << LTC_PIN);
            } else {
                LTC_GPIO_PORT->BSHR = (1 << (LTC_PIN + 16));
            }
            
            ltc_sub_bit = 0;
            ltc_bit_index++;
        }

        // Frame klaar? Reset de bit index naar 0 voor het volgende frame
        if (ltc_bit_index >= 80) {
            ltc_bit_index = 0;
            ltc_sub_bit = 0;
        }
    }
}

