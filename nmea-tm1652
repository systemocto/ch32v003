void UART1_SendString(char *str) {
    while(*str) {
        UART1_SendChar(*str++);
    }
}

// Bare-metal functie om een getal zonder printf() over de UART te sturen
void UART1_SendUint32(uint32_t getal) {
    char buffer[11];
    int i = 10;
    buffer[i] = '\0';
    
    if (getal == 0) {
        UART1_SendChar('0');
        return;
    }
    
    while (getal > 0 && i > 0) {
        i--;
        buffer[i] = (getal % 10) + '0';
        getal /= 10;
    }
    UART1_SendString(&buffer[i]);
}


