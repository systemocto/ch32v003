void Klok_VerwerkInterneTijd(void) {
    // Schuif de tijd-as op met de dynamisch geleerde fixed-point waarde
    start_systick_seconde += (uint32_t)(gemiddelde_seconde_fixed / 1000ULL);

    // Start de PPS-flits synchroon met de vrije klok
    //GPIOD->BSHR = (1 << 4); // PD4 HOOG (LED AAN)
    GPIOD->BSHR = (1 << (4 + 16)); // PD4 LAAG (Geïnverteerde LED gaat nu AAN)
    pps_led_start_tijd = SysTick->CNT;
    pps_led_actief = 1;

    interne_seconden++;
    if (interne_seconden >= 60) {
        interne_seconden = 0;
        interne_minuten++;
        if (interne_minuten >= 60) {
            interne_minuten = 0;
            interne_uren++;
            if (interne_uren >= 24) interne_uren = 0;
        }
    }

    // Elke seconde het display verversen én het proprietary bericht uitsturen
    if (freerunning_modus)
        TM1652_DisplayTijd(interne_uren, interne_minuten, 1);
}

void UART1_SendChar(char c) {
    uint32_t start_bit;
    
    // Live berekening van de exacte bit-duur
    uint32_t bit_tijd_gekalibreerd = (uint32_t)(gemiddelde_seconde_fixed / 115200000ULL);

    // CRUCIAL FIX: Zet interrupts TIJDELIJK UIT om bit-timing te beschermen
    __disable_irq();

    // 1. START BIT (LAAG)
    GPIOD->BSHR = (1 << (5 + 16)); 
    start_bit = SysTick->CNT;
    while((SysTick->CNT - start_bit) < bit_tijd_gekalibreerd);

    // 2. DATA BITS (8 stuks, LSB eerst)
    for (uint8_t i = 0; i < 8; i++) {
        if (c & 0x01) {
            GPIOD->BSHR = (1 << 5); 
        } else {
            GPIOD->BSHR = (1 << (5 + 16)); 
        }
        start_bit += bit_tijd_gekalibreerd;
        while((SysTick->CNT - start_bit) < bit_tijd_gekalibreerd);
        c >>= 1;
    }

    // 3. STOP BIT (HOOG)
    GPIOD->BSHR = (1 << 5); 
    start_bit += bit_tijd_gekalibreerd;
    while((SysTick->CNT - start_bit) < bit_tijd_gekalibreerd);
    
    // CRUCIAL FIX: Zet interrupts DIRECT weer AAN
    __enable_irq();

    // Korte rustpauze tussen karakters (buiten de kritieke interrupt-lock)
    Delay_us(5);
}

