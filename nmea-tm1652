int main(void) {
    SystemInitBareMetal_HSE_24MHz();
//  SystemInitBareMetal_HSI_24MHz();
//    SystemInitBareMetal_HSI_48MHz();


    SysTick->CTLR = 0x00000005;     
    Peripherals_Init();
    Pure_Hardware_I2C_Slave_Init();
//    I2C_EEPROM_VulTestpatroon();
    Flash_BlankCheck_Init();

    i2c_eeprom[0x00] = BRIGHTNESS;
    i2c_eeprom[0x17] = (uint8_t)tijdzone_offset; // Cast naar uint8_t voor de array

    // Register 0x03 is Configuration. Waarde 0xF0 = 1111 0000 (Bit 0,1,2,3 = Output, rest = Input)
    PCF9557_WriteRegister(0x03, 0xF0);
    PCF9557_WriteRegister(0x01, 0x0f);
    dipsw = PCF9557_LeesHogeBits();

    UART1_SendString("NMEA clock ID:"); UART1_SendUint32(dipsw); UART1_SendString("\r\n");

        // Toon de opstart-streepjes
    TM1652_SendByte(0x08);
    TM1652_SendByte(0x40); TM1652_SendByte(0x40); TM1652_SendByte(0x40); TM1652_SendByte(0x40);
    Delay_us(5000);
    TM1652_SendByte(0x18); TM1652_SendByte(0x1C);
    UART1_DetecteerBaudrate();

    // Stuur een melding naar de PC dat we succesvol gelockt zijn
    UART1_SendString("NMEA clock input detected [Auto-Baud]: ");
    UART1_SendUint32(BaudrateTabel[huidige_baudrate_index]);
    UART1_SendString(" baud!\r\n");

    LTC_Timer_Init();
#ifdef IRIGOUT
    IRIG_Init();
#endif

    start_systick_seconde = SysTick->CNT;
    laatste_gps_pakket_tijd = SysTick->CNT;
    start_systick_frame = SysTick->CNT;


    while(1) {
        if (nieuwe_tijd_beschikbaar) {
            start_systick_frame = SysTick->CNT;
            Klok_VerwerkGPS();
        }

        if (!freerunning_modus && (SysTick->CNT - laatste_gps_pakket_tijd) > TIMEOUT_CYCLI) {
            freerunning_modus = 1; 
        }

        if( freerunning_modus != freerunning_modus_old) {
            if(freerunning_modus) 
                UART1_SendString("clocksource: internal\r\n");
            else
                UART1_SendString("clocksource: NMEA\r\n");
            freerunning_modus_old = freerunning_modus;
        }


        if (pps_led_actief && (SysTick->CNT - pps_led_start_tijd) >= 1200000) {
            GPIOD->BSHR = (1 << 4); // PD4 HOOG (Geïnverteerde LED gaat nu UIT)
            //PCF9557_WriteRegister(0x01, 0x01);
            pps_led_actief = 0;

            int32_t mdeg = 99000;
            //mdeg = TMP102_LeesMillidegrees();
    
            i2c_eeprom[0x1C] = (uint8_t)((mdeg >> 16) & 0xFF); // Hoogste byte (Bits 16-23)
            i2c_eeprom[0x1D] = (uint8_t)((mdeg >> 8)  & 0xFF); // Middelste byte (Bits 8-15)
            i2c_eeprom[0x1E] = (uint8_t)(mdeg         & 0xFF); // Laagste byte  (Bits 0-7)
        }

        // 3. Update de tijd autonoom elke seconde
        if ((SysTick->CNT - start_systick_seconde) >= (uint32_t)(gemiddelde_seconde_fixed >> FILTER_SHIFT)) {
            Klok_VerwerkInterneTijd();
        }

        
        i2c_eeprom[0x10] = interne_uren;
        i2c_eeprom[0x11] = interne_minuten;
        i2c_eeprom[0x12] = interne_seconden;
        i2c_eeprom[0x14] = interne_dag;
        i2c_eeprom[0x15] = interne_maand;
        i2c_eeprom[0x16] = interne_jaar;


    
        tijdzone_offset = (int8_t) i2c_eeprom[0x17]; // Cast naar int8_t voor de array
        brightness = i2c_eeprom[0x00];
        ltc_fr_offset = (int16_t)i2c_eeprom[0x06] - 127;
        irig_ms_offset = (int32_t)i2c_eeprom[0x07] - 127;
        // In de main loop (voorkom dat 255 voor rare sprongen zorgt):
        if (i2c_eeprom[0x06] == 255) i2c_eeprom[0x06] = 127; // Reset naar 0 offset
        if (i2c_eeprom[0x07] == 255) i2c_eeprom[0x07] = 127; // Reset naar 0 offset


        I2C_EEPROM_VerwerkPolling();
        if (trigger_flash_write) {
            trigger_flash_write = 0; // Reset de vlag direct
            Flash_Save_EEPROM_Page(); // Sla de eerste 32 bytes veilig op
        }

        uint8_t i2c_waarde = i2c_eeprom[0x02];
        if (i2c_waarde > 16) {
            flash_write_interval = 16;
        } else {
            flash_write_interval = i2c_waarde;
        }

        __asm("nop"); 
    }
}
