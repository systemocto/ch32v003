/* 
 * Start op het Externe 24 MHz Kristal (HSE) voor maximale frequentiestabiliteit
 */
void SystemInitBareMetal_HSE_24MHz(void) {
    RCC->APB2PCENR |= RCC_AFIOEN; // AFIO inschakelen
    RCC->CTLR |= RCC_HSEON;       // Start het externe kristal (24 MHz)
    while((RCC->CTLR & RCC_HSERDY) == 0); // Wacht tot het stabiel trilt

    FLASH->ACTLR = 0;             // Flash op 0 wait states (optimaal voor 24 MHz)
    RCC->CFGR0 = RCC_SW_HSE;      // Schakel om naar het 24 MHz kristal
    while((RCC->CFGR0 & RCC_SWS) != RCC_SWS_HSE); // Wacht op hardwarebevestiging
}

void SystemInitBareMetal_HSI_24MHz(void) {
    // 1. Schakel HSI in (High-Speed Internal RC)
    RCC->CTLR |= RCC_HSION;
    
    // 2. Wacht tot de HSI stabiel is
    while((RCC->CTLR & RCC_HSIRDY) == 0);

    // 3. Zet Flash op 0 wait states (optimaal voor 24 MHz)
    FLASH->ACTLR = 0;

    // 4. Forceer de klokdeler naar DIV1 (wist de DIV8 van de fabriek)
    // SW = 00 (Kies HSI als systeemklok)
    RCC->CFGR0 = 0x00000000; 
}

void SystemInitBareMetal_HSI_48MHz(void) {
    // 1. Schakel HSI (24 MHz) in
    RCC->CTLR |= RCC_HSION;
    
    // 2. Wacht tot de HSI stabiel is
    while((RCC->CTLR & RCC_HSIRDY) == 0);

    // 3. CRUCIAAL VOOR 48 MHz: Flash Latency op 1 Wait State zetten!
    // Zonder deze regel crasht de processor direct bij de omschakeling naar 48 MHz.
    FLASH->ACTLR = FLASH_ACTLR_LATENCY_1;

RCC->CFGR0 &= ~(0x000007F0); 

    // 4. Schakel de PLL (multiplier) in om 24 MHz te verdubbelen naar 48 MHz
    RCC->CTLR |= RCC_PLLON;

    // 5. Wacht tot de PLL stabiel en gelockt is [INDEX]
    while((RCC->CTLR & RCC_PLLRDY) == 0);

    // 6. Schakel de systeemklok-bron om van HSI (24MHz) naar PLL (48MHz)
    // Bit 1 inschakelen (RCC_SW_PLL oftewel 0x02) selecteert de PLL [INDEX]
    RCC->CFGR0 = (RCC->CFGR0 & ~RCC_SW) | RCC_SW_PLL;

    // 7. Wacht tot de hardware bevestigt dat de PLL nu actief is als systeemklok [INDEX]
    while((RCC->CFGR0 & RCC_SWS) != RCC_SWS_PLL);
}

/* 
 * Microseconden delay via de SysTick hardware counter
 */
void Delay_us(uint32_t us) {
    uint32_t start = SysTick->CNT;
    
    uint32_t cycli = (us * gecalibreerde_cycli_per_us_fixed) >> FILTER_SHIFT; 
    
    while((SysTick->CNT - start) < cycli);
}

void Peripherals_Init(void) {
    RCC->APB2PCENR |= RCC_AFIOEN | RCC_IOPCEN | RCC_IOPDEN | RCC_USART1EN; 
    RCC->APB1PCENR |= RCC_I2C1EN;   // Klok voor Hardware I2C1

    // PC3 als Push-Pull Output (0x3) voor TM1652
    //GPIOC->CFGLR &= ~(0xF << 12);  GPIOC->CFGLR |= (0x3 << 12); 
    GPIOC->CFGLR &= ~((0xF << 4) | (0xF << 8) | (0xF << 12)); 

    // PC1 (SDA) -> 0xC (Alternate Function Open-Drain)
    // PC2 (SCL) -> 0xC (Alternate Function Open-Drain)
    // PC3 (Disp)-> 0x3 (Normal Output Push-Pull)
    GPIOC->CFGLR |=  ((0xC << 4) | (0xC << 8) | (0x3 << 12));   
    SDA_HIGH(); 

    // PD6 als Input Floating (0x4) voor Hardware USART1 RX (GPS)
    GPIOD->CFGLR &= ~(0xF << 24); GPIOD->CFGLR |= (0x4 << 24);   

    // UPDATE: PD5 als NORMALE Output Push-Pull (0x3) voor 115200 Bit-Bang TX naar PC
    GPIOD->CFGLR &= ~(0xF << 20); GPIOD->CFGLR |= (0x3 << 20);   
    GPIOD->BSHR = (1 << 5); // Ruststand van UART TX is HOOG

    // UPDATE: PD4 als NORMALE Output Push-Pull (0x3) voor de PPS-LED (Geïnverteerd)
    GPIOD->CFGLR &= ~(0xF << 16); GPIOD->CFGLR |= (0x3 << 16);   
    GPIOD->BSHR = (1 << 4); // Geïnverteerd opstarten (LED staat UIT)

    // Activeer vanaf nu alleen de ONTVANGER (RE) en de interrupt. De zender (TE) slopen we eruit!
    USART1->CTLR1 = 0;USART1->CTLR2 = 0;USART1->CTLR3 = 0;
    USART1->CTLR1 &= ~USART_CTLR1_TE; // Zorg dat hardware-TX uit staat
    USART1->CTLR1 |= USART_CTLR1_UE | USART_CTLR1_RE | USART_CTLR1_RXNEIE;

    NVIC_EnableIRQ(USART1_IRQn);
    SysTick->CTLR = 0x00000005; 
}

const uint32_t BaudrateTabel[] = {230400, 115200, 38400, 19200, 9600, 4800, 57600};
#define AANTAL_BAUDRATES (sizeof(BaudrateTabel) / sizeof(BaudrateTabel[0]))

volatile uint8_t huidige_baudrate_index = 0;
volatile uint8_t baudrate_gevonden = 0;

// Minimale initialisatie van de UART-ontvanger om te kunnen scannen
void UART1_ScanInit(uint32_t baudrate) {
    USART1->CTLR1 &= ~USART_CTLR1_UE;
    USART1->BRR = (uint16_t)(EEN_SECONDE_CYCLI / baudrate);
    // Zet alleen de USART en de ontvanger (RE) aan, nog GEEN interrupts
    USART1->CTLR1 |= USART_CTLR1_UE | USART_CTLR1_RE; 
}

void UART1_DetecteerBaudrate(void) {
    uint32_t start_tijd;
    
    // Zorg dat de RX pin (PD6) als input floating staat
    RCC->APB2PCENR |= RCC_IOPDEN | RCC_USART1EN;
    GPIOD->CFGLR &= ~(0xF << 24);
    GPIOD->CFGLR |=  (0x4 << 24);

    while (!baudrate_gevonden) {
        uint32_t test_baudrate = BaudrateTabel[huidige_baudrate_index];
        UART1_ScanInit(test_baudrate);
        
        // Wacht maximaal 1,5 seconde op deze baudrate om een '$' te spotten
        start_tijd = SysTick->CNT;
//        const uint32_t ANDERHALVE_SECONDE = 72000000;
        const uint32_t ANDERHALVE_SECONDE = (EEN_SECONDE_CYCLI + (EEN_SECONDE_CYCLI/2));
        
        while ((SysTick->CNT - start_tijd) < ANDERHALVE_SECONDE) {
            // Controleer of er een byte klaarstaat in het hardware register
            if (USART1->STATR & USART_STATR_RXNE) {
                char c = (char)(USART1->DATAR);
                if (c == '$') {
                    baudrate_gevonden = 1;
                    break; // Gevonden! Verlaat de tijdsloop
                }
            }
        }
        
        // Als er na 1,5 seconde geen '$' is gezien, probeer de volgende index
        if (!baudrate_gevonden) {
            huidige_baudrate_index++;
            if (huidige_baudrate_index >= AANTAL_BAUDRATES) {
                huidige_baudrate_index = 0; // Begin weer vooraan
            }
        }
    }
}

