void Flash_BlankCheck_Init(void) {
    uint8_t *flash_ptr = (uint8_t*)FLASH_EEPROM_PAGE_ADDR;
    uint8_t is_blank = 1;

    // 1. Controleer of de eerste 32 bytes van de Flash-pagina volledig leeg (0xFF) zijn
    for (int i = 0; i < 32; i++) {
        if (flash_ptr[i] != 0xFF) {
            is_blank = 0; // Er staat al data in de flash!
            break;
        }
    }

    // 2. Als de Flash leeg is, laad fabrieksinstellingen (defaults) in RAM en sla ze op
    if (is_blank) {
        // Wis eerst de gehele array naar 0
        for (int i = 0; i < EEPROM_SIZE; i++) {
            i2c_eeprom[i] = 0x00;
        }

        // Specifieke default waarden toewijzen volgens onze EEPROM map:
        i2c_eeprom[0x00] = 0x00; // Systeem Status OK
        i2c_eeprom[0x01] = 0x07; // Max helderheid display (TM1652)
        i2c_eeprom[0x02] = 0x00; // Flash schrijf interval standaard UIT (0)
        i2c_eeprom[0x04] = 0x02; // DST / Zomertijd op Automatisch
        i2c_eeprom[0x05] = 0x00; // Display modus (Standaard Tijd)
        i2c_eeprom[0x06] = 0x00; // LTC Frame Offset = 0 frames
        i2c_eeprom[0x07] = 0x00; // IRIG-B ms Offset = 0 ms
        i2c_eeprom[0x17] = 0x01; // Tijdzone UTC+1 (Nederlandse wintertijd)

        // Sla deze fabrieksinstellingen direct permanent op in de Flash
        // Zodat bij de volgende boot de pagina niet meer als 'blank' wordt gezien
        Flash_Save_EEPROM_Page();
    } 
    // 3. Als de Flash al geconfigureerde data bevat, laad deze in de RAM-array
    else {
        for (int i = 0; i < 32; i++) {
            i2c_eeprom[i] = flash_ptr[i];
        }
    }
}


// Hulpfunctie om 1 byte naar een specifiek register van de PCF9557 te schrijven
void PCF9557_WriteRegister(uint8_t reg, uint8_t value)
{
    // 1. Wacht tot de bus vrij is
    while(I2C1->STAR2 & I2C_STAR2_BUSY);

    // 2. Genereer START conditie
    I2C1->CTLR1 |= I2C_CTLR1_START;
    while(!(I2C1->STAR1 & I2C_STAR1_SB)); // Wacht op Start Bit vlag

    // 3. Stuur PCF9557 adres + Write bit (0x18 << 1 = 0x30)
    // Let op: Omdat je eigen slave adres ook 0x30 is, moet de CH32 tijdelijk 
    // uit Slave-modus. I2C hardware handelt dit automatisch af als Master.
    I2C1->DATAR = (PCF9557_ADDRESS << 1);
    while(!(I2C1->STAR1 & I2C_STAR1_ADDR));
    (void)I2C1->STAR2; // Wis ADDR vlag

    // 4. Stuur het register-adres
    I2C1->DATAR = reg;
    while(!(I2C1->STAR1 & I2C_STAR1_TXE)); // Wacht tot buffer leeg is

    // 5. Stuur de data-waarde
    I2C1->DATAR = value;
    while(!(I2C1->STAR1 & I2C_STAR1_TXE));

    // 6. Genereer STOP conditie
    I2C1->CTLR1 |= I2C_CTLR1_STOP;
}

uint8_t PCF9557_LeesHogeBits(void)
{
    uint8_t raw_input = 0;

    // 1. Wacht tot de bus vrij is
    while(I2C1->STAR2 & I2C_STAR2_BUSY);

    // 2. STAP 1: Selecteer register 0x00 (Input Port) via een Write-actie
    I2C1->CTLR1 |= I2C_CTLR1_START;
    while(!(I2C1->STAR1 & I2C_STAR1_SB)); // Wacht op Start Bit

    // Stuur adres + Write (0x18 << 1 = 0x30)
    I2C1->DATAR = (PCF9557_ADDRESS << 1);
    while(!(I2C1->STAR1 & I2C_STAR1_ADDR));
    (void)I2C1->STAR2; // Wis ADDR vlag

    // Stuur het register-adres 0x00 (Input Port)
    I2C1->DATAR = 0x00;
    while(!(I2C1->STAR1 & I2C_STAR1_TXE)); // Wacht tot buffer leeg is

    // 3. STAP 2: Schakel om naar Read-modus met een REPEATED START
    I2C1->CTLR1 |= I2C_CTLR1_START;
    while(!(I2C1->STAR1 & I2C_STAR1_SB));

    // Stuur adres + Read bit ( (0x18 << 1) | 1 = 0x31 )
    I2C1->DATAR = (PCF9557_ADDRESS << 1) | 1;
    while(!(I2C1->STAR1 & I2C_STAR1_ADDR));
    
    // Omdat we maar EEN enkele byte willen lezen, moeten we de ACK nu alvast 
    // uitschakelen (NACK) en de STOP-conditie klaarzetten VOORDAT we de ADDR-vlag wissen!
    I2C1->CTLR1 &= ~I2C_CTLR1_ACK; // Geef NACK na de eerste byte
    I2C1->CTLR1 |= I2C_CTLR1_STOP; // Genereer direct een STOP na de byte

    (void)I2C1->STAR2; // Wis de ADDR vlag, de hardware leest nu de byte in

    // Wacht tot de byte volledig binnen is in het dataregister (RXNE)
    while(!(I2C1->STAR1 & I2C_STAR1_RXNE));
    raw_input = I2C1->DATAR; // Lees de ruwe 8-bits waarde uit

    // Herstel de ACK-stand voor je eigen I2C Slave-modus
    I2C1->CTLR1 |= I2C_CTLR1_ACK;

    // 4. Filter en retourneer alleen de 4 hoge bits (bits 4, 5, 6 en 7)
    // Een bitwise AND met 0xF0 (1111 0000) wist de onderste 4 bits.
    // Daarna schuiven we ze 4 posities naar rechts om een getal tussen 0 en 15 te krijgen.
    return (raw_input & 0xF0) >> 4;
}

int32_t TMP102_LeesMillidegrees(void)
{
    uint8_t msb = 0, lsb = 0;

    while(I2C1->STAR2 & I2C_STAR2_BUSY);

    // STAP 1: Selecteer register 0x00
    I2C1->CTLR1 |= I2C_CTLR1_START;
    while(!(I2C1->STAR1 & I2C_STAR1_SB));
    I2C1->DATAR = (TMP102_ADDRESS << 1);
    while(!(I2C1->STAR1 & I2C_STAR1_ADDR));
    (void)I2C1->STAR2;

    I2C1->DATAR = 0x00;
    while(!(I2C1->STAR1 & I2C_STAR1_TXE));

    // STAP 2: Schakel om naar Read-modus
    I2C1->CTLR1 |= I2C_CTLR1_START;
    while(!(I2C1->STAR1 & I2C_STAR1_SB));
    I2C1->DATAR = (TMP102_ADDRESS << 1) | 1;
    while(!(I2C1->STAR1 & I2C_STAR1_ADDR));
    (void)I2C1->STAR2;

    // LEES MSB
    while(!(I2C1->STAR1 & I2C_STAR1_RXNE));
    msb = I2C1->DATAR;

    // Zet NACK en STOP klaar voor de laatste byte
    I2C1->CTLR1 &= ~I2C_CTLR1_ACK;
    I2C1->CTLR1 |= I2C_CTLR1_STOP;

    // LEES LSB
    while(!(I2C1->STAR1 & I2C_STAR1_RXNE));
    lsb = I2C1->DATAR;

    // Herstel ACK voor eigen Slave-modus
    I2C1->CTLR1 |= I2C_CTLR1_ACK;

    // VERWERK NAAR MILLIDEGREES
    int16_t temp_raw = (msb << 4) | (lsb >> 4);
    if (temp_raw & (1 << 11)) {
        temp_raw |= 0xF000; // Sign-extend naar 16-bit signed
    }

    // Door de cast naar (int32_t) verloopt de vermenigvuldiging gegarandeerd overflow-veilig
    return ((int32_t)temp_raw * 625) / 10;
}


