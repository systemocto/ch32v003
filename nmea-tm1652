// Segment-definities voor de cijfers 0 t/m 9 van de TM1652
const uint8_t CijferTabel[] = {
    0x3f, 0x06, 0x5b, 0x4f, 0x66, 0x6d, 0x7d, 0x07, 0x7f, 0x6f
};

uint8_t  brightness = BRIGHTNESS;
const uint8_t BrightTabel[] = {
    0x00, 0x04, 0x02, 0x06, 0x01, 0x05, 0x03, 0x07
};

/* 
 * Bit-bang functie om 1 byte te verzenden via 19200 Baud met Oneven (ODD) Pariteit
 */
void TM1652_SendByte(uint8_t byte) {
#ifndef TM1652OUT

#else
    uint8_t parity_bit = 1; // Start op 1 voor ODD pariteit

    SDA_LOW(); // 1. START BIT (Altijd LAAG)
    Delay_us(52); // Bitduur bij 19200 baud is ~52 microseconden

    // 2. DATA BITS (8 stuks, LSB eerst)
    for (uint8_t i = 0; i < 8; i++) {
        if (byte & 0x01) {
            SDA_HIGH(); parity_bit ^= 1;
        } else {
            SDA_LOW();
        }
        Delay_us(52); byte >>= 1;
    }

    // 3. PARITEIT BIT (ODD)
    if (parity_bit) SDA_HIGH(); else SDA_LOW(); 
    Delay_us(52);

    SDA_HIGH(); // 4. STOP BIT (Altijd HOOG)
    Delay_us(52);
    Delay_us(50); // Inter-packet pauze
#endif
}

/* 
 * Stuurt de uren en minuten naar de TM1652 display registers
 */
void TM1652_DisplayTijd(uint8_t u, uint8_t m, uint8_t dp, uint8_t dp4) {
#ifndef TM1652OUT
#else
    uint8_t u1 = u / 10;
    uint8_t u2 = u % 10;
    uint8_t m1 = m / 10;
    uint8_t m2 = m % 10;

    TM1652_SendByte(0x08); // Startadres voor display-cijfer data
    TM1652_SendByte(CijferTabel[u1]);
    
    if (dp) {
        TM1652_SendByte(CijferTabel[u2] | 0x80); 
    } else {
        TM1652_SendByte(CijferTabel[u2]);        
    }
    TM1652_SendByte(CijferTabel[m1]);
    if (dp4) {
        TM1652_SendByte(CijferTabel[m2] | 0x80); 
    } else {
        TM1652_SendByte(CijferTabel[m2]);        
    }

    Delay_us(500);
    TM1652_SendByte(0x18); // Adres voor Helderheid/Mode regeling
//    TM1652_SendByte(0x18 + (BrightTabel[brightness] & 0x07) << 1); // Display AAN, Mode 8x5, Helderheid level <brightness>
    TM1652_SendByte(0x18 + ((BrightTabel[brightness] & 0x07) << 1)); // Display AAN, Mode 8x5, Helderheid level <brightness>
//    TM1652_SendByte(0x1c);        
#endif
}


