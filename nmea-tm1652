/* 
 * Hardware Interrupt Handler - Verwerkt NMEA op 115200 baud parallel op de achtergrond
 */
void USART1_IRQHandler(void) __attribute__((interrupt("WCH-Interrupt-fast")));
void USART1_IRQHandler(void) {
    if(USART1->STATR & USART_STATR_RXNE) {
        char c = (char)(USART1->DATAR);

        // NMEA Parser State Machine (Detecteert $xxRMC)
        if (c == '$') { nmea_state = 1; return; }
        if (nmea_state == 1 && c == 'G') { nmea_state = 2; return; }
        if (nmea_state == 2 && (c == 'P' || c == 'N')) { nmea_state = 3; return; }
        if (nmea_state == 3 && c == 'R') { nmea_state = 4; return; }
        if (nmea_state == 4 && c == 'M') { nmea_state = 5; return; }
        if (nmea_state == 5 && c == 'C') { 
            nmea_state = 6; komma_teller = 0; tijd_index = 0; datum_index = 0; return; 
        }

        if (nmea_state == 6) {
            if (c == ',') {
                komma_teller++;
                if (komma_teller == 10) {
                    nieuwe_tijd_beschikbaar = 1; //en datum
                    nmea_state = 0;
                }
            return;
            }

            if (komma_teller == 1) {
                if (tijd_index < 6) { tijd_buffer[tijd_index++] = c; }
            } 
            else if (komma_teller == 9) {
                if (datum_index < 6) { datum_buffer[datum_index++] = c; }
            }
        }

    }
}

/* 
 * Genereert en zendt een proprietary NMEA-bericht met live kristal-kalibratiedata
 * Formaat: $PWCHCLK,hele_hz,fractie_mhz,baudrate_index*CS\r\n
 */
void UART1_ZendProprietaryData(void) {
    char body[64];
    uint8_t checksum = 0;
    int idx = 0;
    uint32_t fractie;

    uint32_t actuele_hz_puur = gemiddelde_seconde_fixed >> FILTER_SHIFT;
    uint32_t totale_hz_milli = (gemiddelde_seconde_fixed * 1000) >> FILTER_SHIFT;
    uint32_t hele_hz = actuele_hz_puur;

    int64_t exact_verschil_milli = (int64_t)totale_hz_milli - ((int64_t)NOMINALE_SECONDE_CYCLI * 1000LL);
    #define PPM_DELER (NOMINALE_SECONDE_CYCLI / 1000000UL)
    actuele_ppm = (int32_t)(exact_verschil_milli / (int64_t)PPM_DELER);


    // 1. Bouw de NMEA proprietary header: POH1CL1
    body[idx++] = 'P'; body[idx++] = 'O'; body[idx++] = 'H';
    body[idx++] = 'C'; body[idx++] = 'L'; body[idx++] = 'K'; body[idx++] = '1';
    body[idx++] = ',';

    // 2. Voeg Hele Hz toe (bijv. 24000120)
    uint32_t temp = hele_hz;
    int start_idx = idx;
    if (temp == 0) {
        body[idx++] = '0';
    } else {
        while (temp > 0) {
            body[idx++] = (temp % 10) + '0';
            temp /= 10;
        }
        // Omdraaien omdat we van achter naar voren hebben opgebouwd
        for (int i = 0; i < (idx - start_idx) / 2; i++) {
            char t = body[start_idx + i];
            body[start_idx + i] = body[idx - 1 - i];
            body[idx - 1 - i] = t;
        }
    }
    body[idx++] = '.';

    // 3. Voeg Fractie mHz toe met voorloop-nullen (bijv. 045)
    // VEILIGHEIDSMODULO: Garandeert dat 'fractie' NOOIT groter is dan 999
    uint32_t schone_fractie = fractie % 1000;

    body[idx++] = (schone_fractie / 100) + '0';
    body[idx++] = ((schone_fractie % 100) / 10) + '0';
    body[idx++] = (schone_fractie % 10) + '0';
    
    body[idx++] = 'M';
    body[idx++] = 'H';
    body[idx++] = 'z';
    body[idx++] = ',';


/*
    // 4.1 PPM
    if (actuele_ppm < 0) {
        body[idx++] = '-';
        actuele_ppm = -actuele_ppm; // Maak positief voor de cijfer-extractie
    } else {
        body[idx++] = '+';
    }
    // 4.2 Extraheer alle cijfers (geschikt voor waarden van 0 tot 22000 PPM)
    uint32_t ppm_getal = (uint32_t)actuele_ppm % 100000;

    uint8_t c_10000 = ppm_getal / 10000;
    uint8_t c_1000  = (ppm_getal % 10000) / 1000;
    uint8_t c_100   = (ppm_getal % 1000) / 100;
    uint8_t c_10    = (ppm_getal % 100) / 10;
    uint8_t c_1     = ppm_getal % 10;

    // 4.3 Voeg de cijfers toe met voorloop-nullen (bijv. +00450)
    body[idx++] = c_10000 + '0';
    body[idx++] = c_1000 + '0';
    body[idx++] = c_100 + '0';
    body[idx++] = c_10 + '0';
    body[idx++] = c_1 + '0';

    // 4.4 Voeg de eenheid toe
    body[idx++] = 'P';
    body[idx++] = 'P';
    body[idx++] = 'M';
    body[idx++] = ',';
*/

    // 5. Voeg de actieve Lock-Baudrate Index toe (0 t/m 5)
    body[idx++] = huidige_baudrate_index + '0';
    body[idx++] = ',';

    // 6. Voeg de DIPSW toe (0 t/m 15)
    body[idx++] = dipsw + '0';
    body[idx++] = ',';

    // 7. Voeg de actieve clocksource Index toe (0 t/m 1)
    body[idx++] = freerunning_modus + '0';


    // --- CHECKSUM BEREKENING ---
    for (int i = 0; i < idx; i++) {
        checksum ^= body[i];
    }

    // --- VERZENDING OVER UART (PD5) ---
    UART1_SendChar('$'); 
    
    for (int i = 0; i < idx; i++) {
        UART1_SendChar(body[i]);
    }
    
    UART1_SendChar('*'); 
    
    // Checksum omzetten naar 2 hex-karakters
    uint8_t high_nibble = (checksum >> 4) & 0x0F;
    uint8_t low_nibble  = checksum & 0x0F;
    UART1_SendChar(high_nibble < 10 ? high_nibble + '0' : high_nibble - 10 + 'A');
    UART1_SendChar(low_nibble < 10 ? low_nibble + '0' : low_nibble - 10 + 'A');
    
    UART1_SendChar('\r');
    UART1_SendChar('\n');
}

/* 
 * Genereert en zendt een geldige $GNRMC zin op basis van de interne kloktijd
 * Formaat: $GNRMC,hhmmss.00,A,5213.1234,N,00510.1234,E,0.0,0.0,220626,,,A*CS\r\n
 */
void UART1_ZendGNRMC(void) {
    char nmea_body[80];
    uint8_t checksum = 0;
    int idx = 0;
    uint8_t nmea_buffer_ptr = 0x20;

    // We bouwen de string handmatig op in een tijdelijke buffer (zonder zware sprintf)
    // De string begint direct NA de '$' voor de checksum berekening
    nmea_body[idx++] = 'G'; nmea_body[idx++] = 'N';
    nmea_body[idx++] = 'R'; nmea_body[idx++] = 'M'; nmea_body[idx++] = 'C';
    nmea_body[idx++] = ',';
    
    // Tijd: hhmmss.00
    nmea_body[idx++] = (interne_uren / 10) + '0';   nmea_body[idx++] = (interne_uren % 10) + '0';
    nmea_body[idx++] = (interne_minuten / 10) + '0'; nmea_body[idx++] = (interne_minuten % 10) + '0';
    nmea_body[idx++] = (interne_seconden / 10) + '0'; nmea_body[idx++] = (interne_seconden % 10) + '0';
    
    nmea_body[idx++] = '.'; nmea_body[idx++] = '0'; nmea_body[idx++] = '0';
    nmea_body[idx++] = ',';
    
    // Status: A = Valid (Geldige fix), V = invalid
//    nmea_body[idx++] = 'A';
    nmea_body[idx++] = freerunning_modus ? 'V': 'A';
    nmea_body[idx++] = ',';
    
    // Fictieve Positie (52°13.12345' N, 005°10.12345' E)
    nmea_body[idx++] = '5'; nmea_body[idx++] = '2'; nmea_body[idx++] = '1'; nmea_body[idx++] = '3';
    nmea_body[idx++] = '.'; nmea_body[idx++] = '1'; nmea_body[idx++] = '2'; nmea_body[idx++] = '3';
    nmea_body[idx++] = '4'; nmea_body[idx++] = '5'; nmea_body[idx++] = ','; nmea_body[idx++] = 'N'; nmea_body[idx++] = ',';
    nmea_body[idx++] = '0'; nmea_body[idx++] = '0'; nmea_body[idx++] = '5'; nmea_body[idx++] = '1';
    nmea_body[idx++] = '0'; nmea_body[idx++] = '.'; nmea_body[idx++] = '1'; nmea_body[idx++] = '2';
    nmea_body[idx++] = '3'; nmea_body[idx++] = '4'; nmea_body[idx++] = '5'; nmea_body[idx++] = ','; nmea_body[idx++] = 'E';
    nmea_body[idx++] = ',';
    
    // Snelheid en koers (0.0, 0.0)
    nmea_body[idx++] = '0'; nmea_body[idx++] = '.'; nmea_body[idx++] = '0'; nmea_body[idx++] = ',';
    nmea_body[idx++] = '0'; nmea_body[idx++] = '.'; nmea_body[idx++] = '0'; nmea_body[idx++] = ',';
    
    // Datum: DDMMYY
    nmea_body[idx++] = (interne_dag / 10) + '0';   nmea_body[idx++] = (interne_dag % 10) + '0';
    nmea_body[idx++] = (interne_maand / 10) + '0'; nmea_body[idx++] = (interne_maand % 10) + '0';
    nmea_body[idx++] = (interne_jaar / 10) + '0'; nmea_body[idx++] = (interne_jaar % 10) + '0';
    nmea_body[idx++] = ',';
    
    nmea_body[idx++] = ',';
    
    // Magnetische variatie (leeg)
    nmea_body[idx++] = ',';
    
    // NMEA 2.3+ Mode indicator: A = Autonomous
    nmea_body[idx++] = freerunning_modus ? 'N': 'A';
    nmea_body[idx++] = ',';
    nmea_body[idx++] = ',';

    // NMEA 4.10 Navigational Status: V =  Not Valid
    nmea_body[idx++] = 'V';

    // --- CHECKSUM BEREKENING ---
    // XOR alle karakters in de buffer met elkaar
    for (int i = 0; i < idx; i++) {
        checksum ^= nmea_body[i];
    }

    nmea_buffer_ptr = 0x20;
    for (int i = 0; i < idx; i++) {
        i2c_eeprom[nmea_buffer_ptr] = nmea_body[i];
        nmea_buffer_ptr++;
        if (nmea_buffer_ptr >= 0x80) {
            nmea_buffer_ptr = 0x20; 
        }
    }



    // --- VERZENDING OVER UART (PD5) ---
    UART1_SendChar('$'); // Startteken (telt niet mee voor checksum) [|]
    
    // Zend de body van de RMC zin
    for (int i = 0; i < idx; i++) {
        UART1_SendChar(nmea_body[i]);
    }
    
    UART1_SendChar('*'); // Checksum scheidingsteken [|]
    
    // Converteer de checksum byte naar 2 hexadecimale ASCII karakters (bijv. 0x4A -> "4A") [|]
    uint8_t high_nibble = (checksum >> 4) & 0x0F;
    uint8_t low_nibble  = checksum & 0x0F;
    
    UART1_SendChar(high_nibble < 10 ? high_nibble + '0' : high_nibble - 10 + 'A');
    UART1_SendChar(low_nibble < 10 ? low_nibble + '0' : low_nibble - 10 + 'A');
    
    // NMEA afsluiter
    UART1_SendChar('\r');
    UART1_SendChar('\n');
}


