void UART1_SendChar(char c) {
    uint32_t start_bit;
    #define DELER_UART      (115200ULL * (1ULL << FILTER_SHIFT))
    // Live berekening van de exacte bit-duur

    uint32_t bit_tijd_gekalibreerd = gemiddelde_seconde_fixed / (uint32_t)DELER_UART;

    __disable_irq();

    // 1. START BIT (LAAG)
    GPIOD->BSHR = (1 << (5 + 16)); 
    start_bit = SysTick->CNT;
    while((SysTick->CNT - start_bit) < bit_tijd_gekalibreerd);

    // 2. DATA BITS (8 stuks, LSB eerst)
    for (uint8_t i = 0; i < 8; i++) {
        if (c & 0x01) {
            GPIOD->BSHR = (1 << 5); 
        } else {
            GPIOD->BSHR = (1 << (5 + 16)); 
        }
        start_bit += bit_tijd_gekalibreerd;
        while((SysTick->CNT - start_bit) < bit_tijd_gekalibreerd);
        c >>= 1;
    }

    // 3. STOP BIT (HOOG)
    GPIOD->BSHR = (1 << 5); 
    start_bit += bit_tijd_gekalibreerd;
    while((SysTick->CNT - start_bit) < bit_tijd_gekalibreerd);
    
    __enable_irq();

    // Korte rustpauze tussen karakters (buiten de kritieke interrupt-lock)
    Delay_us(5);
}

