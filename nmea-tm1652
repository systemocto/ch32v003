void Flash_Unlock(void) {
    if (FLASH->CTLR & FLASH_CTLR_LOCK) {
        FLASH->KEYR = 0x45670123; // Sleutel 1
        FLASH->KEYR = 0xCDEF89AB; // Sleutel 2
    }
}

void Flash_Lock(void) {
    FLASH->CTLR |= FLASH_CTLR_LOCK;
}

void Flash_Save_EEPROM_Page(void) {
    // 1. Ontgrendel de Flash controller
    Flash_Unlock();

    // 2. Wis de specifieke 64-byte pagina (Page Erase)
    FLASH->CTLR |= FLASH_CTLR_PER;                 // Selecteer Page Erase modus
    FLASH->ADDR = FLASH_EEPROM_PAGE_ADDR;          // Geef het doeladres op
    FLASH->CTLR |= FLASH_CTLR_STRT;                // Start de wis-operatie
    while (FLASH->STATR & FLASH_STATR_BSY);        // Wacht tot de controller klaar is
    FLASH->CTLR &= ~FLASH_CTLR_PER;                // Schakel Page Erase modus weer uit

    // 3. Schrijf 32 bytes (als 16 opeenvolgende half-words / 16-bit getallen)
    FLASH->CTLR |= FLASH_CTLR_PG;                  // Selecteer Program (Schrijf) modus
    
    uint32_t target_addr = FLASH_EEPROM_PAGE_ADDR;
    for (int i = 0; i < 32; i += 2) {
        // Combineer twee 8-bit bytes uit de RAM-array naar één 16-bit half-word (Little Endian)
        uint16_t half_word = i2c_eeprom[i] | (i2c_eeprom[i + 1] << 8);
        
        *(volatile uint16_t*)target_addr = half_word; // Schrijf naar het Flash-adres
        while (FLASH->STATR & FLASH_STATR_BSY);      // Wacht tot het schrijven klaar is
        target_addr += 2;                             // Schuif 2 bytes op
    }

    FLASH->CTLR &= ~FLASH_CTLR_PG;                 // Schakel Program modus weer uit

    // 4. Vergrendel de Flash controller weer ter beveiliging
    Flash_Lock();
}


