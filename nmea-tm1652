volatile uint8_t i2c_eeprom[EEPROM_SIZE] = {0}; // De virtuele EEPROM in RAM

// Statusvariabelen voor de I2C state-machine
volatile uint8_t i2c_reg_pointer = 0;   // Wijst naar het huidige virtuele EEPROM-adres
volatile uint8_t i2c_first_byte = 1;    // Geeft aan of de master net is gestart (voor de pointer)

void Pure_Hardware_I2C_Slave_Init(void)
{
    GPIO_InitTypeDef GPIO_InitStructure = {0};
    I2C_InitTypeDef  I2C_InitTSturcture = {0};

    // 1. Schakel de klokken in via de MounRiver SPL (GPIOC, I2C1 en AFIO)
    RCC_APB2PeriphClockCmd(RCC_APB2Periph_GPIOC | RCC_APB2Periph_AFIO, ENABLE);
    RCC_APB1PeriphClockCmd(RCC_APB1Periph_I2C1, ENABLE);

    // 2. Configureer PC1 (SDA) en PC2 (SCL) als Alternate Function Open-Drain
    GPIO_InitStructure.GPIO_Pin = GPIO_Pin_1 | GPIO_Pin_2;
    GPIO_InitStructure.GPIO_Mode = GPIO_Mode_AF_OD; 
    GPIO_InitStructure.GPIO_Speed = GPIO_Speed_50MHz;
    GPIO_Init(GPIOC, &GPIO_InitStructure);

    // 3. Reset de hardware module om alle interne registers te cleanen
    I2C1->CTLR1 |= I2C_CTLR1_SWRST;             
    I2C1->CTLR1 &= ~I2C_CTLR1_SWRST;

    // 4. Configureer de hardware registers
    I2C_InitTSturcture.I2C_ClockSpeed = 100000; // 100kHz standaard snelheid
    I2C_InitTSturcture.I2C_Mode = I2C_Mode_I2C; 
    I2C_InitTSturcture.I2C_DutyCycle = I2C_DutyCycle_2; 
    I2C_InitTSturcture.I2C_OwnAddress1 = (I2C_SLAVE_ADDRESS << 1); // 7-bit adres verschuiven
    I2C_InitTSturcture.I2C_Ack = I2C_Ack_Enable; 
    I2C_InitTSturcture.I2C_AcknowledgedAddress = I2C_AcknowledgedAddress_7bit; 
    I2C_Init(I2C1, &I2C_InitTSturcture);

    // Dit verbiedt de hardware om SCL laag te houden. De bus kan nu nooit meer hangen!
//    I2C1->CTLR1 |= I2C_CTLR1_NOSTRETCH;

    // 5. Schakel de I2C module definitief in
    I2C_Cmd(I2C1, ENABLE);
}

void I2C_EEPROM_VerwerkPolling(void) {
    uint32_t star1 = I2C1->STAR1;

    // 1. ADDR Vlag: De Pi heeft ons adres (0x30) aangeroepen
    if (star1 & I2C_STAR1_ADDR) {
        i2c_first_byte = 1; 
        
        // WCH SPECIFIEKE EVENT: Lees STAR1 (reeds gedaan) en direct daarna STAR2.
        // Dit wist de ADDR vlag en geeft de kloklijn (SCL) direct weer vrij!
        volatile uint32_t star2 = I2C1->STAR2; 
        (void)star2;
        
        // Leg direct alvast de ALLEREERSTE mogelijke byte klaar in de buffer 
        // voor het geval dat de master direct een Read-actie start.
        I2C1->DATAR = i2c_eeprom[i2c_reg_pointer];
    }

    // 2. RXNE Vlag: De Pi schrijft data naar ons (Pointer of registerwaarde)
    if (star1 & I2C_STAR1_RXNE) {
        uint8_t received_byte = I2C1->DATAR; // Het lezen wist de RXNE vlag automatisch
        
        if (i2c_first_byte) {
            i2c_reg_pointer = received_byte % EEPROM_SIZE; // Set de veilige 256-bytes pointer
            i2c_first_byte = 0;
        } else {
            i2c_eeprom[i2c_reg_pointer] = received_byte; 
            i2c_reg_pointer = (i2c_reg_pointer + 1) % EEPROM_SIZE; 
        }
    }

    // 3. TXE Vlag: De Pi wil een byte uit ons register lezen (i2cdump)
    if (star1 & I2C_STAR1_TXE) {
        // Vul direct het dataregister. Doordat SCL gerekt mag worden, 
        // wacht de Pi netjes tot deze regel is uitgevoerd!
        I2C1->DATAR = i2c_eeprom[i2c_reg_pointer]; 
        i2c_reg_pointer = (i2c_reg_pointer + 1) % EEPROM_SIZE; 
    }

    // 4. STOPF Vlag: De Pi sluit de transactie netjes af met een STOP
    if (star1 & I2C_STAR1_STOPF) {
        // Wist de STOPF vlag door CTLR1 naar zichzelf terug te schrijven
        I2C1->CTLR1 = I2C1->CTLR1; 
    }

    // 5. AF / BERR Vlag: Herstel bij ACK-failure (gebeurt standaard aan het einde van elke i2cdump regel)
    if (star1 & (I2C_STAR1_BERR | I2C_STAR1_AF)) {
        I2C1->STAR1 &= ~(I2C_STAR1_BERR | I2C_STAR1_AF); // Wis de foutvlaggen om de bus te deblokkeren
    }
}

void I2C_EEPROM_VulTestpatroon(void)
{
    for (uint16_t i = 0; i < EEPROM_SIZE; i++)
    {
        i2c_eeprom[i] = (uint8_t)i; 
    }
}

/* 
 * Hardware Interrupt Handler - Verwerkt NMEA op 115200 baud parallel op de achtergrond
 */
void USART1_IRQHandler(void) __attribute__((interrupt("WCH-Interrupt-fast")));
void USART1_IRQHandler(void) {
    if(USART1->STATR & USART_STATR_RXNE) {
        char c = (char)(USART1->DATAR);

        // --- TRANSPARANTE GATEWAY ---
        // Stuur elke binnengekomen byte van de GPS direct 1-op-1 door naar de PC!
        //while((USART1->STATR & USART_STATR_TXE) == 0); // Wacht tot TX-buffer vrij is
        //USART1->DATAR = c;
        // ----------------------------

        // NMEA Parser State Machine (blijft ongewijzigd op de achtergrond meeluisteren)
        if (c == '$') { nmea_state = 1; return; }
        if (nmea_state == 1 && c == 'G') { nmea_state = 2; return; }
        if (nmea_state == 2 && (c == 'P' || c == 'N')) { nmea_state = 3; return; }
        if (nmea_state == 3 && c == 'R') { nmea_state = 4; return; }
        if (nmea_state == 4 && c == 'M') { nmea_state = 5; return; return; }
        if (nmea_state == 5 && c == 'C') { 
            nmea_state = 6; komma_teller = 0; tijd_index = 0; return; 
        }

        if (nmea_state == 6) {
            if (c == ',') { komma_teller++; return; }
            if (komma_teller == 1) {
                if (tijd_index < 6) { tijd_buffer[tijd_index++] = c; }
            } 
            else if (komma_teller == 2) {
                nieuwe_tijd_beschikbaar = 1;
                nmea_state = 0; 
            }
        }
    }
}

/* 
 * Genereert en zendt een proprietary NMEA-bericht met live kristal-kalibratiedata
 * Formaat: $PWCHCLK,hele_hz,fractie_mhz,baudrate_index*CS\r\n
 */
void UART1_ZendProprietaryData(void) {
    char body[64];
    uint8_t checksum = 0;
    int idx = 0;

    // Haal de gekalibreerde fixed-point waarden op
    uint32_t hele_hz = (uint32_t)(gemiddelde_seconde_fixed / 1000ULL);
    uint32_t fractie  = (uint32_t)(gemiddelde_seconde_fixed % 1000ULL);

    // 1. Bouw de NMEA proprietary header: POH1CL1
    body[idx++] = 'P'; body[idx++] = 'O'; body[idx++] = 'H';
    body[idx++] = 'C'; body[idx++] = 'L'; body[idx++] = 'K'; body[idx++] = '1';
    body[idx++] = ',';

    // 2. Voeg Hele Hz toe (bijv. 24000120)
    uint32_t temp = hele_hz;
    int start_idx = idx;
    if (temp == 0) {
        body[idx++] = '0';
    } else {
        while (temp > 0) {
            body[idx++] = (temp % 10) + '0';
            temp /= 10;
        }
        // Omdraaien omdat we van achter naar voren hebben opgebouwd
        for (int i = 0; i < (idx - start_idx) / 2; i++) {
            char t = body[start_idx + i];
            body[start_idx + i] = body[idx - 1 - i];
            body[idx - 1 - i] = t;
        }
    }
    body[idx++] = ',';

    // 3. Voeg Fractie mHz toe met voorloop-nullen (bijv. 045)
    body[idx++] = (fractie / 100) + '0';
    body[idx++] = ((fractie % 100) / 10) + '0';
    body[idx++] = (fractie % 10) + '0';
    body[idx++] = ',';

    // 4. Voeg de actieve Lock-Baudrate Index toe (0 t/m 5)
    body[idx++] = huidige_baudrate_index + '0';
    body[idx++] = ',';

    // 4. Voeg de actieve clocksource Index toe (0 t/m 1)
    body[idx++] = freerunning_modus + '0';

    // --- CHECKSUM BEREKENING ---
    for (int i = 0; i < idx; i++) {
        checksum ^= body[i];
    }

    // --- VERZENDING OVER UART (PD5) ---
    UART1_SendChar('$'); 
    
    for (int i = 0; i < idx; i++) {
        UART1_SendChar(body[i]);
    }
    
    UART1_SendChar('*'); 
    
    // Checksum omzetten naar 2 hex-karakters
    uint8_t high_nibble = (checksum >> 4) & 0x0F;
    uint8_t low_nibble  = checksum & 0x0F;
    UART1_SendChar(high_nibble < 10 ? high_nibble + '0' : high_nibble - 10 + 'A');
    UART1_SendChar(low_nibble < 10 ? low_nibble + '0' : low_nibble - 10 + 'A');
    
    UART1_SendChar('\r');
    UART1_SendChar('\n');
}

void Klok_VerwerkGPS(void) {
    nieuwe_tijd_beschikbaar = 0;
    freerunning_modus = 0; 
    laatste_gps_pakket_tijd = SysTick->CNT; 

    uint8_t gps_u = ((tijd_buffer[0] - '0') * 10) + (tijd_buffer[1] - '0');
    uint8_t gps_m = ((tijd_buffer[2] - '0') * 10) + (tijd_buffer[3] - '0');
    uint8_t gps_s = ((tijd_buffer[4] - '0') * 10) + (tijd_buffer[5] - '0');

    if (gps_u < 24 && gps_m < 60 && gps_s < 60) {
        uint32_t nu_systick = SysTick->CNT;
        if (eerste_sync_gehad) {
            uint32_t werkelijke_cycli = nu_systick - laatste_gps_systick;
            if (werkelijke_cycli > 23900000 && werkelijke_cycli < 24100000) {
                uint64_t huidige_meting_fixed = (uint64_t)werkelijke_cycli * 1000ULL;
                if (huidige_meting_fixed > gemiddelde_seconde_fixed) {
                    gemiddelde_seconde_fixed += (huidige_meting_fixed - gemiddelde_seconde_fixed) >> 10;
                } else {
                    gemiddelde_seconde_fixed -= (gemiddelde_seconde_fixed - huidige_meting_fixed) >> 10;
                }
            }
        } else {
            eerste_sync_gehad = 1;
        }
        laatste_gps_systick = nu_systick;

        int8_t lokale_uren = gps_u + TIMEZONE_OFFSET;
        if (lokale_uren >= 24)      lokale_uren -= 24;
        else if (lokale_uren < 0)  lokale_uren += 24;

        interne_uren = (uint8_t)lokale_uren;
        interne_minuten = gps_m;
        interne_seconden = gps_s;
        
        start_systick_seconde = nu_systick; 
        dubbelepunt_aan = (interne_seconden % 2 == 0);
        
        TM1652_DisplayTijd(interne_uren, interne_minuten, dubbelepunt_aan);

        // Start de PPS-flits synchroon met de GPS
        //GPIOD->BSHR = (1 << 4); // PD4 HOOG (LED AAN)
        GPIOD->BSHR = (1 << (4 + 16)); // PD4 LAAG (Geïnverteerde LED gaat nu AAN)
        pps_led_start_tijd = SysTick->CNT;
        pps_led_actief = 1;

        // Injecteer het proprietary kalibratiebericht
        UART1_ZendProprietaryData();
        //UART1_ZendGNRMC();
    }
